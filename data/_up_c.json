[{"path": "ui/index.html", "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>WildKeys</title>\n  <link rel=\"icon\" href=\"logo.ico\" type=\"image/x-icon\" />\n  <link rel=\"stylesheet\" href=\"styles.css?v=icon-pad28\" />\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\" />\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin />\n  <link href=\"https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@500;600&family=Outfit:wght@400;500;600;700&display=swap\" rel=\"stylesheet\" media=\"print\" onload=\"this.media='all'\" />\n  <noscript>\n    <link href=\"https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@500;600&family=Outfit:wght@400;500;600;700&display=swap\" rel=\"stylesheet\" />\n  </noscript>\n</head>\n<body>\n  <div class=\"modal-root modal-loading\" id=\"loadingModal\">\n    <div class=\"modal-backdrop\"></div>\n    <div class=\"modal modal-sm loading-card\" role=\"status\" aria-live=\"polite\" aria-busy=\"true\">\n      <div class=\"loading-body\">\n        <img class=\"loading-logo\" src=\"logo.png\" width=\"56\" height=\"56\" alt=\"\" />\n        <h2 class=\"loading-title\">Loading</h2>\n        <p class=\"loading-sub\">Starting WildKeys\u2026</p>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"app\">\n    <header class=\"titlebar\" id=\"titlebar\">\n      <div class=\"titlebar-drag\" id=\"titlebarDrag\">\n        <div class=\"brand\">\n          <div class=\"mark\">\n            <img class=\"mark-logo\" src=\"logo.png\" width=\"36\" height=\"36\" alt=\"\" />\n          </div>\n          <div class=\"brand-text\">\n            <h1>WildKeys</h1>\n            <p class=\"brand-byline\">by Charlotte Chapdelaine</p>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"titlebar-right\">\n        <div class=\"win-controls\" aria-label=\"Window controls\">\n          <button type=\"button\" class=\"modal-close win-chrome\" id=\"winMin\" title=\"Minimize\" aria-label=\"Minimize\">\n            <img class=\"chrome-icon\" src=\"minimize.svg\" width=\"10\" height=\"10\" alt=\"\" draggable=\"false\" />\n          </button>\n          <button type=\"button\" class=\"modal-close win-chrome win-close\" id=\"winClose\" title=\"Close\" aria-label=\"Close\">\n            <img class=\"chrome-icon\" src=\"x.svg\" width=\"10\" height=\"10\" alt=\"\" draggable=\"false\" />\n          </button>\n        </div>\n      </div>\n    </header>\n\n    <div class=\"app-body\">\n    <main class=\"layout\">\n      <section class=\"deck-panel\">\n        <div class=\"panel-head deck-head\">\n          <h2>Shortcut Deck</h2>\n          <label class=\"toggle\" title=\"Enable or pause global hotkeys\">\n            <input type=\"checkbox\" id=\"enabledToggle\" checked />\n            <span class=\"toggle-track\">\n              <span class=\"toggle-thumb\"></span>\n            </span>\n            <span class=\"toggle-label\" id=\"toggleLabel\">Armed</span>\n          </label>\n        </div>\n        <div class=\"deck\" id=\"deck\" role=\"list\"></div>\n        <p class=\"deck-foot\">\n          Each shortcut above can be assigned a list of text entries (right pane).<br />\n          Press the assigned hotkey to paste a random line from that list into the currently focused text field.\n        </p>\n      </section>\n\n      <aside class=\"editor-panel\" id=\"editorPanel\">\n        <div class=\"panel-head editor-head\">\n          <div>\n            <h2 id=\"editorTitle\">Select a key</h2>\n          </div>\n          <div class=\"key-combo editor-keys\" id=\"editorShortcut\" data-key=\"\" aria-label=\"Shortcut\">\n            <span class=\"key-badge mod\">Ctrl</span>\n            <span class=\"key-badge mod\">Alt</span>\n            <span class=\"key-badge letter\" id=\"editorKeyLetter\">\u2014</span>\n          </div>\n        </div>\n\n        <label class=\"field\">\n          <span class=\"field-label\">List Name</span>\n          <input type=\"text\" id=\"labelInput\" maxlength=\"40\" disabled />\n        </label>\n\n        <div class=\"field grow\">\n          <span class=\"field-row\">\n            <span class=\"field-label\">Lines</span>\n            <span class=\"count\" id=\"lineCount\">0</span>\n          </span>\n          <div class=\"lines-editor\" id=\"linesEditor\">\n            <div class=\"line-gutter\" id=\"lineGutter\" aria-hidden=\"true\">1</div>\n            <div class=\"lines-main\">\n              <textarea\n                id=\"linesInput\"\n                spellcheck=\"true\"\n                disabled\n                wrap=\"off\"\n              ></textarea>\n              <img class=\"save-success-gif\" id=\"saveSuccessGif\" src=\"success.gif\" alt=\"\" hidden />\n            </div>\n          </div>\n        </div>\n\n        <div class=\"editor-actions\">\n          <button type=\"button\" class=\"btn ghost\" id=\"previewBtn\" disabled>Preview</button>\n          <button type=\"button\" class=\"btn primary\" id=\"saveBtn\" disabled>Save</button>\n        </div>\n\n        <div class=\"toast\" id=\"toast\" hidden></div>\n      </aside>\n    </main>\n    </div>\n\n  </div>\n\n  <div class=\"modal-root\" id=\"previewModal\" hidden>\n    <div class=\"modal-backdrop\" data-close-modal=\"1\"></div>\n    <div class=\"modal\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"previewModalTitle\">\n      <header class=\"modal-head\">\n        <h2 id=\"previewModalTitle\">Preview</h2>\n        <button type=\"button\" class=\"modal-close\" id=\"previewModalClose\" aria-label=\"Close\">\n          <img class=\"chrome-icon\" src=\"x.svg\" width=\"10\" height=\"10\" alt=\"\" draggable=\"false\" />\n        </button>\n      </header>\n      <div class=\"modal-body\">\n        <p class=\"modal-lead\">Use the text field below to test the active shortcuts.</p>\n        <textarea id=\"previewModalText\" class=\"modal-textarea\" rows=\"5\" spellcheck=\"true\"></textarea>\n      </div>\n      <footer class=\"modal-actions\">\n        <button type=\"button\" class=\"btn primary\" id=\"previewModalDone\">Close</button>\n      </footer>\n    </div>\n  </div>\n\n  <div class=\"modal-root\" id=\"unsavedModal\" hidden>\n    <div class=\"modal-backdrop\" data-close-unsaved=\"cancel\"></div>\n    <div class=\"modal modal-sm\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"unsavedModalTitle\">\n      <header class=\"modal-head\">\n        <h2 id=\"unsavedModalTitle\">Unsaved changes</h2>\n        <button type=\"button\" class=\"modal-close\" id=\"unsavedModalClose\" aria-label=\"Close\">\n          <img class=\"chrome-icon\" src=\"x.svg\" width=\"10\" height=\"10\" alt=\"\" draggable=\"false\" />\n        </button>\n      </header>\n      <div class=\"modal-body\">\n        <p class=\"modal-lead\">You have unsaved changes on this list.<br />Discard them and switch, or keep editing?</p>\n      </div>\n      <footer class=\"modal-actions\">\n        <button type=\"button\" class=\"btn ghost\" id=\"unsavedKeepBtn\">Keep editing</button>\n        <button type=\"button\" class=\"btn primary\" id=\"unsavedDiscardBtn\">Discard</button>\n      </footer>\n    </div>\n  </div>\n\n  <div class=\"modal-root\" id=\"errorModal\" hidden>\n    <div class=\"modal-backdrop\" data-close-error=\"1\"></div>\n    <div class=\"modal modal-sm\" role=\"alertdialog\" aria-modal=\"true\" aria-labelledby=\"errorModalTitle\">\n      <header class=\"modal-head\">\n        <h2 id=\"errorModalTitle\">Cannot save</h2>\n        <button type=\"button\" class=\"modal-close\" id=\"errorModalClose\" aria-label=\"Close\">\n          <img class=\"chrome-icon\" src=\"x.svg\" width=\"10\" height=\"10\" alt=\"\" draggable=\"false\" />\n        </button>\n      </header>\n      <div class=\"modal-body\">\n        <p class=\"modal-lead\" id=\"errorModalLead\">Please enter a list name before saving.</p>\n      </div>\n      <footer class=\"modal-actions\">\n        <button type=\"button\" class=\"btn primary\" id=\"errorModalOk\">OK</button>\n      </footer>\n    </div>\n  </div>\n\n  <script src=\"app.js\"></script>\n</body>\n</html>\n"}, {"path": "ui/minimize.svg", "content": "<svg preserveAspectRatio=\"xMidYMid meet\" id=\"svg8\" viewBox=\"0 0 12.7 12.7\" xmlns=\"http://www.w3.org/2000/svg\" xmlns:cc=\"http://creativecommons.org/ns#\" xmlns:dc=\"http://purl.org/dc/elements/1.1/\" xmlns:inkscape=\"http://www.inkscape.org/namespaces/inkscape\" xmlns:rdf=\"http://www.w3.org/1999/02/22-rdf-syntax-ns#\" xmlns:sodipodi=\"http://sodipodi.sourceforge.net/DTD/sodipodi-0.dtd\" xmlns:svg=\"http://www.w3.org/2000/svg\"><g id=\"layer2\"><path id=\"path915\" d=\"m1.0578165 5.8208289c-.29164903-.0034-.53108703.229777-.53536703.521415-.0044.297707.237649.540418.53536703.536918h10.5843665c.297718.0035.53972-.239211.535368-.536918-.0043-.291638-.243719-.524835-.535368-.521415-3.5281215 0-7.0562445 0-10.5843665 0z\" font-variant-ligatures=\"normal\" font-variant-position=\"normal\" font-variant-caps=\"normal\" font-variant-numeric=\"normal\" font-variant-alternates=\"normal\" font-feature-settings=\"normal\" text-indent=\"0\" text-align=\"start\" text-decoration-line=\"none\" text-decoration-style=\"solid\" text-decoration-color=\"#000000\" text-transform=\"none\" text-orientation=\"mixed\" white-space=\"normal\" shape-padding=\"0\" isolation=\"auto\" mix-blend-mode=\"normal\" solid-color=\"#000000\" solid-opacity=\"1\" vector-effect=\"none\"/></g></svg>"}, {"path": "ui/x.svg", "content": "<svg preserveAspectRatio=\"xMidYMid meet\" id=\"svg8\" viewBox=\"0 0 12.7 12.7\" xmlns=\"http://www.w3.org/2000/svg\" xmlns:cc=\"http://creativecommons.org/ns#\" xmlns:dc=\"http://purl.org/dc/elements/1.1/\" xmlns:inkscape=\"http://www.inkscape.org/namespaces/inkscape\" xmlns:rdf=\"http://www.w3.org/1999/02/22-rdf-syntax-ns#\" xmlns:sodipodi=\"http://sodipodi.sourceforge.net/DTD/sodipodi-0.dtd\" xmlns:svg=\"http://www.w3.org/2000/svg\"><g id=\"layer2\"><path id=\"path1146\" d=\"m1.0655486.5291624c-.13518002-.0018-.27106002.04776-.37569002.149345-.21358.207433-.21453.550559-.001.75861 1.63752002 1.637734 3.27508002 3.275424 4.91288002 4.912878-1.6378 1.637454-3.27536 3.275145-4.91288002 4.9128786-.21298.208051-.21203.551177.001.75861.10463.101587.24051.151129.37569002.149345.13518-.0018.26965-.05484.37155-.159164 1.6371-1.638156 3.27512-3.2753916 4.91288-4.9128776 1.63777 1.637484 3.27579 3.2747216 4.9128814 4.9128776.208051.212986.551177.212052.75861-.0015.203183-.209252.198347-.543432-.01033-.747241-1.637318-1.6379296-3.2751014-3.2754056-4.9128814-4.9128786 1.63778-1.63747 3.2755634-3.274948 4.9128814-4.912878.208682-.203809.213518-.537989.01033-.747241-.207433-.213603-.550559-.214536-.75861-.0016-1.6370914 1.638157-3.2751114 3.275395-4.9128814 4.912879-1.63776-1.637489-3.27578-3.274722-4.91288-4.912879-.1019-.104322-.23637-.157379-.37155-.159164z\" font-variant-ligatures=\"normal\" font-variant-position=\"normal\" font-variant-caps=\"normal\" font-variant-numeric=\"normal\" font-variant-alternates=\"normal\" font-feature-settings=\"normal\" text-indent=\"0\" text-align=\"start\" text-decoration-line=\"none\" text-decoration-style=\"solid\" text-decoration-color=\"#000000\" text-transform=\"none\" text-orientation=\"mixed\" white-space=\"normal\" shape-padding=\"0\" isolation=\"auto\" mix-blend-mode=\"normal\" solid-color=\"#000000\" solid-opacity=\"1\" vector-effect=\"none\"/></g></svg>"}]