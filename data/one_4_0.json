{"path": "ui/index.html", "content": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>WildKeys</title>\n  <link rel=\"icon\" href=\"logo.ico\" type=\"image/x-icon\" />\n  <link rel=\"stylesheet\" href=\"styles.css?v=icon-pad28\" />\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\" />\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin />\n  <link href=\"https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@500;600&family=Outfit:wght@400;500;600;700&display=swap\" rel=\"stylesheet\" media=\"print\" onload=\"this.media='all'\" />\n  <noscript>\n    <link href=\"https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@500;600&family=Outfit:wght@400;500;600;700&display=swap\" rel=\"stylesheet\" />\n  </noscript>\n</head>\n<body>\n  <div class=\"modal-root modal-loading\" id=\"loadingModal\">\n    <div class=\"modal-backdrop\"></div>\n    <div class=\"modal modal-sm loading-card\" role=\"status\" aria-live=\"polite\" aria-busy=\"true\">\n      <div class=\"loading-body\">\n        <img class=\"loading-logo\" src=\"logo.png\" width=\"56\" height=\"56\" alt=\"\" />\n        <h2 class=\"loading-title\">Loading</h2>\n        <p class=\"loading-sub\">Starting WildKeys…</p>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"app\">\n    <header class=\"titlebar\" id=\"titlebar\">\n      <div class=\"titlebar-drag\" id=\"titlebarDrag\">\n        <div class=\"brand\">\n          <div class=\"mark\">\n            <img class=\"mark-logo\" src=\"logo.png\" width=\"36\" height=\"36\" alt=\"\" />\n          </div>\n          <div class=\"brand-text\">\n            <h1>WildKeys</h1>\n            <p class=\"brand-byline\">by Charlotte Chapdelaine</p>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"titlebar-right\">\n        <div class=\"win-controls\" aria-label=\"Window controls\">\n          <button type=\"button\" class=\"modal-close win-chrome\" id=\"winMin\" title=\"Minimize\" aria-label=\"Minimize\">\n            <img class=\"chrome-icon\" src=\"minimize.svg\" width=\"10\" height=\"10\" alt=\"\" draggable=\"false\" />\n          </button>\n          <button type=\"button\" class=\"modal-close win-chrome win-close\" id=\"winClose\" title=\"Close\" aria-label=\"Close\">\n            <img class=\"chrome-icon\" src=\"x.svg\" width=\"10\" height=\"10\" alt=\"\" draggable=\"false\" />\n          </button>\n        </div>\n      </div>\n    </header>\n\n    <div class=\"app-body\">\n    <main class=\"layout\">\n      <section class=\"deck-panel\">\n        <div class=\"panel-head deck-head\">\n          <h2>Shortcut Deck</h2>\n          <label class=\"toggle\" title=\"Enable or pause global hotkeys\">\n            <input type=\"checkbox\" id=\"enabledToggle\" checked />\n            <span class=\"toggle-track\">\n              <span class=\"toggle-thumb\"></span>\n            </span>\n            <span class=\"toggle-label\" id=\"toggleLabel\">Armed</span>\n          </label>\n        </div>\n        <div class=\"deck\" id=\"deck\" role=\"list\"></div>\n        <p class=\"deck-foot\">\n          Each shortcut above can be assigned a list of text entries (right pane).<br />\n          Press the assigned hotkey to paste a random line from that list into the currently focused text field.\n        </p>\n      </section>\n\n      <aside class=\"editor-panel\" id=\"editorPanel\">\n        <div class=\"panel-head editor-head\">\n          <div>\n            <h2 id=\"editorTitle\">Select a key</h2>\n          </div>\n          <div class=\"key-combo editor-keys\" id=\"editorShortcut\" data-key=\"\" aria-label=\"Shortcut\">\n            <span class=\"key-badge mod\">Ctrl</span>\n            <span class=\"key-badge mod\">Alt</span>\n            <span class=\"key-badge letter\" id=\"editorKeyLetter\">—</span>\n          </div>\n        </div>\n\n        <label class=\"field\">\n          <span class=\"field-label\">List Name</span>\n          <input type=\"text\" id=\"labelInput\" maxlength=\"40\" disabled />\n        </label>\n\n        <div class=\"field grow\">\n          <span class=\"field-row\">\n            <span class=\"field-label\">Lines</span>\n            <span class=\"count\" id=\"lineCount\">0</span>\n          </span>\n          <div class=\"lines-editor\" id=\"linesEditor\">\n            <div class=\"line-gutter\" id=\"lineGutter\" aria-hidden=\"true\">1</div>\n            <div class=\"lines-main\">\n              <textarea\n                id=\"linesInput\"\n                spellcheck=\"true\"\n                disabled\n                wrap=\"off\"\n              ></textarea>\n              <img class=\"save-success-gif\" id=\"saveSuccessGif\" src=\"success.gif\" alt=\"\" hidden />\n            </div>\n          </div>\n        </div>\n\n        <div class=\"editor-actions\">\n          <button type=\"button\" class=\"btn ghost\" id=\"previewBtn\" disabled>Preview</button>\n          <button type=\"button\" class=\"btn primary\" id=\"saveBtn\" disabled>Save</button>\n        </div>\n\n        <div class=\"toast\" id=\"toast\" hidden></div>\n      </aside>\n    </main>\n    </div>\n\n  </div>\n\n  <div class=\"modal-root\" id=\"previewModal\" hidden>\n    <div class=\"modal-backdrop\" data-close-modal=\"1\"></div>\n    <div class=\"modal\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"previewModalTitle\">\n      <header class=\"modal-head\">\n        <h2 id=\"previewModalTitle\">Preview</h2>\n        <button type=\"button\" class=\"modal-close\" id=\"previewModalClose\" aria-label=\"Close\">\n          <img class=\"chrome-icon\" src=\"x.svg\" width=\"10\" height=\"10\" alt=\"\" draggable=\"false\" />\n        </button>\n      </header>\n      <div class=\"modal-body\">\n        <p class=\"modal-lead\">Use the text field below to test the active shortcuts.</p>\n        <textarea id=\"previewModalText\" class=\"modal-textarea\" rows=\"5\" spellcheck=\"true\"></textarea>\n      </div>\n      <footer class=\"modal-actions\">\n        <button type=\"button\" class=\"btn primary\" id=\"previewModalDone\">Close</button>\n      </footer>\n    </div>\n  </div>\n\n  <div class=\"modal-root\" id=\"unsavedModal\" hidden>\n    <div class=\"modal-backdrop\" data-close-unsaved=\"cancel\"></div>\n    <div class=\"modal modal-sm\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"unsavedModalTitle\">\n      <header class=\"modal-head\">\n        <h2 id=\"unsavedModalTitle\">Unsaved changes</h2>\n        <button type=\"button\" class=\"modal-close\" id=\"unsavedModalClose\" aria-label=\"Close\">\n          <img class=\"chrome-icon\" src=\"x.svg\" width=\"10\" height=\"10\" alt=\"\" draggable=\"false\" />\n        </button>\n      </header>\n      <div class=\"modal-body\">\n        <p class=\"modal-lead\">You have unsaved changes on this list.<br />Discard them and switch, or keep editing?</p>\n      </div>\n      <footer class=\"modal-actions\">\n        <button type=\"button\" class=\"btn ghost\" id=\"unsavedKeepBtn\">Keep editing</button>\n        <button type=\"button\" class=\"btn primary\" id=\"unsavedDiscardBtn\">Discard</button>\n      </footer>\n    </div>\n  </div>\n\n  <div class=\"modal-root\" id=\"errorModal\" hidden>\n    <div class=\"modal-backdrop\" data-close-error=\"1\"></div>\n    <div class=\"modal modal-sm\" role=\"alertdialog\" aria-modal=\"true\" aria-labelledby=\"errorModalTitle\">\n      <header class=\"modal-head\">\n        <h2 id=\"errorModalTitle\">Cannot save</h2>\n        <button type=\"button\" class=\"modal-close\" id=\"errorModalClose\" aria-label=\"Close\">\n          <img class=\"chrome-icon\" src=\"x.svg\" width=\"10\" height=\"10\" alt=\"\" draggable=\"false\" />\n        </button>\n      </header>\n      <div class=\"modal-body\">\n        <p class=\"modal-lead\" id=\"errorModalLead\">Please enter a list name before saving.</p>\n      </div>\n      <footer class=\"modal-actions\">\n        <button type=\"button\" class=\"btn primary\" id=\"errorModalOk\">OK</button>\n      </footer>\n    </div>\n  </div>\n\n  <script src=\"app.js\"></script>\n</body>\n</html>\n"}